rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsIncomingDoc() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /bikes/{bikeId} {
      allow create: if ownsIncomingDoc();
      allow read, update, delete: if ownsExistingDoc();
    }

    match /nfcTags/{tagId} {
      allow create: if ownsIncomingDoc();
      allow read, update, delete: if ownsExistingDoc();
    }

    match /reports/{reportId} {
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /trips/{tripId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
  }
}

